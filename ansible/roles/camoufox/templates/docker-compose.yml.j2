services:
  camoufox:
    image: {{ camoufox_image }}
    container_name: camoufox
    restart: unless-stopped
    ports:
      - "{{ camoufox_port }}:{{ camoufox_port }}"
    environment:
      - CAMOUFOX_PORT={{ camoufox_port }}
      - CAMOUFOX_INTERNAL_PORT={{ camoufox_internal_port }}
      - CAMOUFOX_WS_PATH={{ camoufox_ws_path }}
    shm_size: "2gb"
    healthcheck:
      test: ["CMD", "nc", "-z", "127.0.0.1", "{{ camoufox_internal_port }}"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 90s
    logging:
      driver: json-file
      options:
        max-size: "2m"
        max-file: "2"

name: firecrawl

services:
  nuq-postgres:
    image: {{ firecrawl_nuqpg_image }}
    container_name: firecrawl-nuq-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: "{{ firecrawl_pg_password }}"
      POSTGRES_DB: postgres
    volumes:
      - {{ firecrawl_pgdata_dir }}:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 10

  redis:
    image: {{ firecrawl_redis_image }}
    container_name: firecrawl-redis
    restart: unless-stopped
    command: redis-server --bind 0.0.0.0

  playwright-service:
    image: {{ firecrawl_playwright_image }}
    container_name: firecrawl-playwright
    restart: unless-stopped
    environment:
      PORT: "3000"
    cpus: 2.0
    mem_limit: 4G

  api:
    image: {{ firecrawl_api_image }}
    container_name: firecrawl-api
    restart: unless-stopped
    command: node dist/src/harness.js --start-docker
    depends_on:
      nuq-postgres:
        condition: service_healthy
      redis:
        condition: service_started
      playwright-service:
        condition: service_started
    ports:
      - "{{ firecrawl_port }}:3002"
    environment:
      HOST: "0.0.0.0"
      PORT: "3002"
      ENV: local
      USE_DB_AUTHENTICATION: "false"
      NUM_WORKERS_PER_QUEUE: "{{ firecrawl_num_workers }}"
      REDIS_URL: "redis://redis:6379"
      REDIS_RATE_LIMIT_URL: "redis://redis:6379"
      PLAYWRIGHT_MICROSERVICE_URL: "http://playwright-service:3000/scrape"
      POSTGRES_HOST: nuq-postgres
      POSTGRES_PORT: "5432"
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: "{{ firecrawl_pg_password }}"
      POSTGRES_DB: postgres
      NUQ_RABBITMQ_URL: "{{ firecrawl_rabbitmq_url }}"
      SEARXNG_ENDPOINT: "{{ firecrawl_searxng_endpoint }}"
    cpus: 4.0
    mem_limit: 8G

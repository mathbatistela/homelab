---
server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: {{ home_assistant_promtail_loki_url }}

scrape_configs:
  - job_name: home-assistant-logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: home-assistant
          host: ha
          __path__: /var/log/home-assistant/*.log
    pipeline_stages:
      - multiline:
          firstline: '^\d{4}-\d{2}-\d{2}\s+\d{1,2}:\d{2}:\d{2}'
          max_wait_time: 3s
      - regex:
          expression: '^(?P<timestamp>\d{4}-\d{2}-\d{2}\s+\d{1,2}:\d{2}:\d{2}\.\d+)\s+(?P<level>\w+)\s+\((?P<component>[^)]+)\)\s+(?P<message>.*)$'
      - timestamp:
          source: timestamp
          format: '2006-01-02 15:04:05.000000'
      - labels:
          level:
          component:
      - output:
          source: message

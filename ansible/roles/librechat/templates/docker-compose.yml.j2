services:
  librechat:
    container_name: librechat
    image: ghcr.io/danny-avila/librechat:{{ librechat_version }}
    restart: unless-stopped
    ports:
      - "{{ librechat_port }}:{{ librechat_port }}"
    volumes:
      - {{ librechat_data_dir }}:/app/.config/librechat
      - {{ librechat_compose_dir }}/librechat.yaml:/app/librechat.yaml:ro
    environment:
      - HOST=0.0.0.0
      - PORT={{ librechat_port }}
      - NODE_ENV=production
      - MONGO_URI=mongodb://librechat-mongo:27017/LibreChat
      - MEILI_HOST=http://librechat-meili:7700
      - MEILI_MASTER_KEY={{ librechat_meili_key }}
      - JWT_SECRET={{ librechat_jwt_secret }}
      - REFRESH_SECRET={{ librechat_refresh_secret }}
      - CREDS_KEY={{ librechat_creds_key }}
      - CREDS_IV={{ librechat_creds_iv }}
      - CONFIG_BYPASS_VALIDATION=true
      - ALLOW_REGISTRATION=true
    depends_on:
      - librechat-mongo
      - librechat-meili

  librechat-mongo:
    container_name: librechat-mongo
    image: mongo:7
    restart: unless-stopped
    volumes:
      - {{ librechat_data_dir }}/mongo:/data/db

  librechat-meili:
    container_name: librechat-meili
    image: getmeili/meilisearch:v1.11
    restart: unless-stopped
    environment:
      - MEILI_MASTER_KEY={{ librechat_meili_key }}
      - MEILI_NO_ANALYTICS=true
    volumes:
      - {{ librechat_data_dir }}/meili:/meili_data

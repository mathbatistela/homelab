services:
{% for server in mcp_servers %}
  {{ server.name }}:
    container_name: mcp-{{ server.name }}
    image: {{ server.image }}
    restart: unless-stopped
{% if server.command is defined %}
    command:
{% for arg in server.command %}
      - "{{ arg | string }}"
{% endfor %}
{% endif %}
    ports:
      - "{{ server.port }}:{{ server.port }}"
    environment:
{% for key, value in server.env.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
    volumes:
      - {{ mcp_servers_data_dir }}/{{ server.name }}:/data
    networks:
{% for network in server.networks | default([mcp_servers_network_name]) %}
      - {{ network }}
{% endfor %}
{% if server.uid is defined and server.gid is defined %}
    user: "{{ server.uid }}:{{ server.gid }}"
{% endif %}
    healthcheck:
      test: {{ server.healthcheck_test | default('["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:' ~ server.port ~ '/health"]') }}
      interval: {{ server.healthcheck_interval | default('30s') }}
      timeout: {{ server.healthcheck_timeout | default('10s') }}
      retries: {{ server.healthcheck_retries | default(3) }}
      start_period: {{ server.healthcheck_start_period | default('40s') }}
{% endfor %}

  mcpo:
    container_name: {{ mcp_mcpo_container_name }}
    image: {{ mcp_mcpo_image }}
    restart: unless-stopped
    ports:
      - "{{ mcp_mcpo_port }}:{{ mcp_mcpo_port }}"
    command:
      - mcpo
      - --config
      - /app/config.json
      - --port
      - "{{ mcp_mcpo_port }}"
      - --api-key
      - "{{ mcp_mcpo_api_key }}"
    volumes:
      - {{ mcp_servers_data_dir }}/mcpo-config.json:/app/config.json:ro
    networks:
      - {{ mcp_servers_network_name }}
    depends_on:
{% for server in mcp_servers %}
      {{ server.name }}:
        condition: service_healthy
{% endfor %}

networks:
  {{ mcp_servers_network_name }}:
    name: {{ mcp_servers_network_name }}
{% for network in mcp_servers_extra_networks | default([]) %}
  {{ network }}:
    external: true
{% endfor %}

{% set mcpo_servers = [] %}
{% for server in mcp_servers %}
{% if server.mcpo_enabled | default(true) %}
{% set _ = mcpo_servers.append(server) %}
{% endif %}
{% endfor %}
{
  "mcpServers": {
{% for server in mcpo_servers %}
    "{{ server.name }}": {
      "type": "{{ server.mcpo_type | default('streamable-http') }}",
      "url": "http://mcp-{{ server.name }}:{{ server.port }}{{ server.mcp_path | default('/http') }}",
{% if server.mcpo_type | default('streamable-http') == 'sse' %}
      "headers": {},
{% else %}
      "headers": {
        "Authorization": "Bearer {{ mcp_mcpo_api_key }}"
      },
{% endif %}
      "timeout": {{ server.mcpo_timeout | default(60) }}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  }
}
